# Safe demo deployment — see ADR-0013
# Empty value → shell renders "Agent offline — demo mode" (frame-agent not deployed)
VITE_FRAME_AGENT_URL=

# Module Federation remotes — point to Vercel deployment domains
# These values match the sub-domain convention documented in vite.config.ts
VITE_REMOTE_RESUME_BUILDER=https://cv.jim.software
VITE_REMOTE_BLOGENGINE=https://blog.jim.software
VITE_REMOTE_TRIPPLANNER=https://trips.jim.software
VITE_REMOTE_PUREFOY=https://purefoy.jim.software
VITE_REMOTE_CORE_READER=https://reader.jim.software
VITE_REMOTE_LEAN_CANVAS=https://canvas.jim.software
VITE_REMOTE_GASTOWN_PILOT=https://gastown.jim.software
