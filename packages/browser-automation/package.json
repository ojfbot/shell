{
  "name": "@shell/browser-automation",
  "version": "0.1.0",
  "description": "Browser automation service with Playwright for UI testing and screenshot capture",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test:visual": "tsx tests/visual/shell-visual.test.ts",
    "test:visual:update": "UPDATE_BASELINES=true tsx tests/visual/shell-visual.test.ts"
  },
  "keywords": ["playwright", "browser-automation", "screenshot", "testing", "docker"],
  "author": "Shell Team",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pngjs": "^6.0.5",
    "axios": "^1.13.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3"
  }
}
