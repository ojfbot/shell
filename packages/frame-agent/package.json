{
  "name": "@ojfbot/frame-agent",
  "version": "0.1.0",
  "description": "Frame OS — meta-orchestrator LLM gateway for all ojfbot sub-apps",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; tsx watch src/server.ts'",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ojfbot/agent-core": "workspace:*",
    "@anthropic-ai/sdk": "catalog:",
    "cors": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "helmet": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
