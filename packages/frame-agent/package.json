{
  "name": "@ojfbot/frame-agent",
  "version": "0.1.0",
  "description": "Frame OS — meta-orchestrator LLM gateway for all ojfbot sub-apps",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; tsx watch src/server.ts'",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@ojfbot/agent-core": "workspace:*",
    "cors": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "helmet": "catalog:",
    "mysql2": "^3.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@frame/tsconfig": "file:../../../cv-builder/packages/tsconfig",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
