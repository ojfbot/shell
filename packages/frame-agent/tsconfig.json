{
  "extends": "@frame/tsconfig/node.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@ojfbot/agent-core": ["../agent-core/src/index.ts"],
      "@ojfbot/agent-core/agents/*": ["../agent-core/src/agents/*.ts"],
      "@ojfbot/agent-core/middleware/*": ["../agent-core/src/middleware/*.ts"],
      "@ojfbot/agent-core/services/*": ["../agent-core/src/services/*.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
