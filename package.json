{
  "name": "@ojfbot/shell-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @ojfbot/shell-app dev\" \"pnpm --filter @ojfbot/frame-agent dev\"",
    "dev:all": "concurrently \"pnpm --filter @ojfbot/shell-app dev\" \"pnpm --filter @ojfbot/frame-agent dev\"",
    "build": "pnpm --recursive --if-present build",
    "type-check": "pnpm --recursive --if-present type-check",
    "test": "pnpm --recursive --if-present test",
    "e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@frame/tsconfig": "file:../cv-builder/packages/tsconfig",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
